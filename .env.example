# Copy this file to backend/.env and fill in your values.

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Choose one: anthropic | groq | openrouter | ollama
# - anthropic   : best quality, paid (https://console.anthropic.com)
# - groq         : FREE API key, very fast (https://console.groq.com)
# - openrouter   : FREE tier with many models (https://openrouter.ai/keys)
# - ollama       : FREE, runs locally — no internet needed (https://ollama.com)
AI_PROVIDER=openrouter

# ─── Anthropic (paid) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Groq (FREE) — fastest free option ───────────────────────────────────────
# Get a key at https://console.groq.com (takes ~1 minute, no credit card)
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ─── OpenRouter (FREE tier) ───────────────────────────────────────────────────
# Get a key at https://openrouter.ai/keys — free models need $0 balance
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_VISION_MODEL=meta-llama/llama-4-scout:free

# ─── Ollama (FREE, local) ─────────────────────────────────────────────────────
# Install: https://ollama.com  then run:
#   ollama pull qwen2.5-coder   (for text tasks)
#   ollama pull llava            (for vision/image tasks)
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder
# OLLAMA_VISION_MODEL=llava

# ─── Neural 3D mesh generation ────────────────────────────────────────────────
# Image-to-3D providers (first that works wins). Keyless HF Space (Hunyuan3D-2)
# works out of the box; add keys for faster/more reliable generation.
# FAL_KEY=your_fal_key                 # https://fal.ai (recommended primary)
# REPLICATE_API_TOKEN=your_token       # https://replicate.com
# HF_TOKEN=your_hf_read_token          # https://huggingface.co (bigger free quota)
# MESH_HF_SPACES=tencent/Hunyuan3D-2
#
# Text-only generation turns the prompt into a reference image first, then meshes it.
# FAL_TEXT_TO_IMAGE_MODEL=fal-ai/flux/schnell
# HF_TEXT_TO_IMAGE_SPACE=black-forest-labs/FLUX.1-schnell

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
UPLOAD_MAX_AGE_MS=600000
