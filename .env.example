# ─────────────────────────────────────────────────────────────────────────────
# Gen3D environment.  Copy this file to backend/.env and fill in your values:
#     cp .env.example backend/.env
# Every line is optional except ONE AI provider key (see the chain below).
# Lines starting with # are comments / disabled. Remove the # to enable a value.
# ─────────────────────────────────────────────────────────────────────────────

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ AI PROVIDER (text + vision — powers the mesh-edit planner & smart plans)   ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# Gen3D tries providers in a 6-tier fallback chain (first that works wins):
#   1. Anthropic (direct)      2. OpenRouter → Claude      3. AgentRouter → Claude
#   4. OpenRouter (free)       5. Groq (free)              6. Ollama (local)
# Tiers 4–6 are non-Claude "weak" models, OFF by default (ALLOW_WEAK_MODELS).
# You only need ONE Claude-quality key (tier 1, 2, or 3) for good results.
#
# AI_PROVIDER is the *preferred* starting provider for direct (non-chain) calls.
# Options: anthropic | agentrouter | openrouter | groq | ollama
AI_PROVIDER=agentrouter

# ─── Anthropic (direct, paid) ── best quality ──────────────────────────────────
# Key: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── AgentRouter ── "cloud" Anthropic-API gateway → Claude ─────────────────────
# An Anthropic-compatible gateway that proxies to Claude. Key from your AgentRouter dashboard.
AGENTROUTER_API_KEY=your_agentrouter_api_key_here
# AGENTROUTER_MODEL=claude-sonnet-4-5-20250929
# AGENTROUTER_VISION_MODEL=claude-sonnet-4-5-20250929
# Route via a local `claude` CLI subprocess to bypass AgentRouter's non-CLI block.
# Requires:  npm i -g @anthropic-ai/claude-code
# AGENTROUTER_USE_CLI=false

# ─── OpenRouter ── one key, both a Claude tier and a free tier ─────────────────
# Key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Paid Claude-quality models (tier 2):
# OPENROUTER_CLAUDE_MODEL=anthropic/claude-sonnet-4-5
# OPENROUTER_CLAUDE_VISION_MODEL=anthropic/claude-sonnet-4-5
# Free models (tier 4 — needs ALLOW_WEAK_MODELS=true):
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# ─── Groq (FREE, very fast) ── tier 5 ──────────────────────────────────────────
# Key: https://console.groq.com  (~1 min, no credit card)
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ─── Ollama (FREE, local — no internet, no key) ── tier 6 ──────────────────────
# Install: https://ollama.com  then:  ollama pull qwen2.5-coder && ollama pull llava
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder
# OLLAMA_VISION_MODEL=llava

# ─── AI tuning ─────────────────────────────────────────────────────────────────
# Allow the weak non-Claude tiers (4–6) as fallbacks. Off = never silently degrade.
# ALLOW_WEAK_MODELS=false
# AI_MAX_TOKENS=8192
# AI_THINKING_BUDGET=2048          # extended-thinking budget for Anthropic direct (< AI_MAX_TOKENS; 0 disables)

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ NEURAL 3D MESH GENERATION (image → 3D, and text → image → 3D)              ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# Works out of the box with NO key via the public Hugging Face Space (Hunyuan3D-2),
# but that can be slow/queued. Add a FAL_KEY for fast, reliable generation.
# Providers are tried in MESH_PROVIDER_ORDER (first that succeeds wins).
# MESH_PROVIDER_ORDER=fal,replicate,hf

# fal.ai — recommended primary.  Key: https://fal.ai
# FAL_KEY=your_fal_key
# FAL_MESH_MODEL=fal-ai/hunyuan3d/v2
# FAL_MESH_MODELS=fal-ai/hunyuan3d/v2     # comma-list; each becomes its own candidate engine

# Replicate (paid).  Token: https://replicate.com
# REPLICATE_API_TOKEN=your_replicate_token
# REPLICATE_MESH_MODEL=ndreca/hunyuan3d-2

# Hugging Face — bigger free quota on the keyless Space.  Token: https://huggingface.co
# HF_TOKEN=your_hf_read_token
# MESH_HF_SPACES=tencent/Hunyuan3D-2
# MESH_HF_TIMEOUT_MS=120000

# ─── Text → reference image (text-only prompts get an image first, then meshed) ─
# FAL_TEXT_TO_IMAGE_MODEL=fal-ai/flux/schnell
# HF_TEXT_TO_IMAGE_SPACE=black-forest-labs/FLUX.1-schnell
# ─── Image clean-up helpers (best-effort; fal primary, HF Space fallback) ──────
# FAL_REMBG_MODEL=fal-ai/imageutils/rembg          # background removal
# HF_REMBG_SPACE=briaai/BRIA-RMBG-2.0
# FAL_IMAGE_EDIT_MODEL=fal-ai/flux-pro/kontext      # "Reimagine" instruction edit
# HF_IMAGE_EDIT_SPACE=timbrooks/instruct-pix2pix
# FAL_UPSCALE_MODEL=fal-ai/esrgan                   # "Enhance" upscale
# HF_UPSCALE_SPACE=

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ SERVER + PRINTER                                                           ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
PORT=3001
UPLOAD_MAX_AGE_MS=600000
# Path to a CuraEngine / PrusaSlicer binary. Leave empty to use the built-in
# TypeScript slicer fallback.
# SLICER_PATH=

# Moonraker (Klipper printer API) — used by "Send to Printer". The default local
# instance trusts localhost, so no API key is needed. Point this elsewhere if
# Moonraker runs on another host/port.
# MOONRAKER_URL=http://localhost:7125
